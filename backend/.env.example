# Servidor
PORT=4000
NODE_ENV=development

# PostgreSQL (datos del panel)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/nexhost"

# MySQL (bases de datos de clientes)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=tu_password

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_seguro
JWT_EXPIRES_IN=7d

# NextAuth (debe coincidir con el frontend)
NEXTAUTH_SECRET=el_mismo_secreto_que_el_frontend

# Email (para magic link y notificaciones)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASS=tu_app_password
EMAIL_FROM="NexHost <no-reply@nexhost.pe>"

# Google OAuth
GOOGLE_CLIENT_ID=tu_google_client_id
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# URL del frontend
FRONTEND_URL=http://localhost:3000
