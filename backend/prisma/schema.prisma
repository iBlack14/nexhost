generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String           @id @default(uuid())
  email                String           @unique
  name                 String
  password             String?
  role                 Role             @default(CLIENT)
  avatar               String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  account              Account?
  tickets              Ticket[]
  invoices             Invoice[]
  resellerProfile      ResellerProfile?
  ownedHostingAccounts HostingAccount[] @relation("OwnerAccounts")
  resellerAccounts     HostingAccount[] @relation("ResellerAccounts")
  provisionJobs        ProvisionJob[]   @relation("RequestedJobs")
}

enum Role {
  ADMIN
  RESELLER
  CLIENT
}

model ResellerProfile {
  id               String          @id @default(uuid())
  ownerUserId      String          @unique
  owner            User            @relation(fields: [ownerUserId], references: [id])
  maxAccounts      Int             @default(50)
  maxDomains       Int             @default(100)
  status           ResellerStatus  @default(ACTIVE)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

enum ResellerStatus {
  ACTIVE
  SUSPENDED
}

model HostingAccount {
  id            String               @id @default(uuid())
  username      String               @unique
  primaryDomain String               @unique
  ownerUserId   String
  owner         User                 @relation("OwnerAccounts", fields: [ownerUserId], references: [id])
  resellerUserId String?
  reseller      User?                @relation("ResellerAccounts", fields: [resellerUserId], references: [id])
  planName      String?
  status        HostingAccountStatus @default(PROVISIONING)
  homeDir       String?
  docRoot       String?
  ipAddress     String?
  port          Int?
  sslEnabled    Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  dnsZones      DnsZone[]
  jobs          ProvisionJob[]
}

enum HostingAccountStatus {
  PROVISIONING
  ACTIVE
  SUSPENDED
  FAILED
}

model DnsZone {
  id               String      @id @default(uuid())
  hostingAccountId String?
  hostingAccount   HostingAccount? @relation(fields: [hostingAccountId], references: [id])
  domain           String      @unique
  cloudflareZoneId String?
  syncStatus       String      @default("PENDING")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  records          DnsRecord[]
}

model DnsRecord {
  id                String        @id @default(uuid())
  zoneId            String
  zone              DnsZone       @relation(fields: [zoneId], references: [id])
  type              DnsRecordType
  name              String
  content           String
  ttl               Int           @default(300)
  proxied           Boolean       @default(false)
  cloudflareRecordId String?
  status            String        @default("PENDING")
  createdAt         DateTime      @default(now())
}

enum DnsRecordType {
  A
  CNAME
  TXT
}

model ProvisionJob {
  id               String             @id @default(uuid())
  hostingAccountId String?
  hostingAccount   HostingAccount?    @relation(fields: [hostingAccountId], references: [id])
  requestedById    String?
  requestedBy      User?              @relation("RequestedJobs", fields: [requestedById], references: [id])
  type             ProvisionJobType   @default(CREATE_HOSTING_ACCOUNT)
  status           ProvisionJobStatus @default(PENDING)
  payload          Json?
  retries          Int                @default(0)
  error            String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  startedAt        DateTime?
  completedAt      DateTime?
  steps            ProvisionJobStep[]
}

model ProvisionJobStep {
  id          String              @id @default(uuid())
  jobId        String
  job          ProvisionJob       @relation(fields: [jobId], references: [id])
  step         String
  status       ProvisionStepStatus @default(PENDING)
  output       Json?
  error        String?
  createdAt    DateTime            @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
}

enum ProvisionJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ProvisionStepStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ProvisionJobType {
  CREATE_HOSTING_ACCOUNT
}

model ServiceStatusSnapshot {
  id          String   @id @default(uuid())
  nginx       String
  mysql       String
  postgresql  String
  pm2         String
  diskUsage   Float
  ramUsage    Float
  cpuUsage    Float
  capturedAt  DateTime @default(now())
}

model Account {
  id        String        @id @default(uuid())
  userId    String        @unique
  user      User          @relation(fields: [userId], references: [id])
  planId    String
  plan      Plan          @relation(fields: [planId], references: [id])
  status    AccountStatus @default(ACTIVE)
  expiresAt DateTime
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  domains   Domain[]
  databases Database[]
  emails    EmailAccount[]
  nodeApps  NodeApp[]
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  PENDING
  EXPIRED
}

model Plan {
  id           String    @id @default(uuid())
  name         String    @unique
  displayName  String
  price        Float
  diskGB       Int
  ramMB        Int
  bandwidth    Int
  maxDomains   Int
  maxDatabases Int
  maxEmails    Int
  maxNodeApps  Int
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  accounts     Account[]
  invoices     Invoice[]
}

model Domain {
  id         String       @id @default(uuid())
  accountId  String
  account    Account      @relation(fields: [accountId], references: [id])
  name       String       @unique
  type       DomainType   @default(STATIC)
  phpVersion String?
  sslActive  Boolean      @default(false)
  sslExpiry  DateTime?
  status     DomainStatus @default(ACTIVE)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

enum DomainType {
  WORDPRESS
  NODE
  STATIC
  PHP
}

enum DomainStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Database {
  id        String   @id @default(uuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id])
  dbName    String
  dbUser    String
  sizeBytes BigInt   @default(0)
  createdAt DateTime @default(now())
}

model EmailAccount {
  id        String   @id @default(uuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id])
  address   String   @unique
  quotaMB   Int      @default(5120)
  usedMB    Int      @default(0)
  createdAt DateTime @default(now())
}

model NodeApp {
  id        String    @id @default(uuid())
  accountId String
  account   Account   @relation(fields: [accountId], references: [id])
  name      String
  port      Int       @unique
  domain    String?
  status    AppStatus @default(STOPPED)
  pm2Id     Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

enum AppStatus {
  RUNNING
  STOPPED
  ERROR
}

model Ticket {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  subject   String
  status    TicketStatus   @default(OPEN)
  priority  Priority       @default(MEDIUM)
  messages  TicketMessage[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model TicketMessage {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  fromAdmin Boolean  @default(false)
  body      String
  createdAt DateTime @default(now())
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Invoice {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  planId    String
  plan      Plan          @relation(fields: [planId], references: [id])
  amount    Float
  status    InvoiceStatus @default(PENDING)
  paidAt    DateTime?
  dueDate   DateTime
  createdAt DateTime      @default(now())
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}
